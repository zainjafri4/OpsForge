# Database Connection
# Local: Use Docker PostgreSQL (see docker-compose.yml)
# Production: Use managed PostgreSQL (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://postgres:password@localhost:5432/devops_forge"

# JWT Configuration
# IMPORTANT: Generate secure secrets for production using: openssl rand -base64 32
# These are LOCAL DEVELOPMENT values only - NEVER use in production!
JWT_SECRET="dev-jwt-secret-key-for-local-development-only-replace-in-prod"
JWT_REFRESH_SECRET="dev-refresh-secret-for-local-only-replace-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server Configuration
PORT=3001

# CORS - Frontend URL (where your Next.js app runs)
# Local: http://localhost:3000
# Production: https://your-frontend-domain.vercel.app
FRONTEND_URL="http://localhost:3000"
